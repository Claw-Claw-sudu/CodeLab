<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Secret Dashboard | CodeLab</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            black: '#000000',
            white: '#ffffff',
            gray100: '#f5f5f5',
            gray200: '#e5e5e5',
            danger: '#dc2626',
            success: '#16a34a'
          }
        }
      }
    }
  </script>
</head>
<body class="bg-gray100 min-h-screen p-4">

  <!-- 🔑 LOGIN SCREEN -->
  <div id="loginScreen" class="max-w-md mx-auto mt-20 bg-white p-6 rounded-xl shadow-lg border border-gray200 text-center">
    <i class="fa fa-lock text-4xl text-black mb-3"></i>
    <h1 class="text-xl font-bold mb-2">Secret Dashboard</h1>
    <p class="text-sm text-gray-600 mb-4">Enter keycode to access</p>
    <input type="password" id="keyInput" placeholder="Enter Keycode" class="w-full p-3 border border-gray200 rounded-lg mb-3 text-center text-lg">
    <button onclick="checkKey()" class="w-full bg-black text-white p-3 rounded-lg font-medium">Login</button>
    <p class="text-xs text-gray-500 mt-3">Link: /secret-dashboard-jojo67 | Key: 8867</p>
  </div>

  <!-- 🛡️ DASHBOARD (AFTER LOGIN) -->
  <div id="dashboardScreen" class="hidden max-w-4xl mx-auto">
    <div class="bg-white rounded-xl shadow-lg border border-gray200 p-5 mb-5">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-xl font-bold flex items-center gap-2"><i class="fa fa-shield"></i> Blocked Users Panel</h1>
        <button onclick="logout()" class="text-sm text-danger">Logout</button>
      </div>

      <!-- 🔍 SEARCH BAR -->
      <div class="mb-4">
        <input type="text" id="searchInput" placeholder="Search by name..." oninput="filterUsers()" class="w-full p-3 border border-gray200 rounded-lg">
      </div>

      <!-- 📋 BLOCKED USERS LIST -->
      <div id="blockedList" class="space-y-3">
        <p class="text-gray-500 text-center py-5">Loading blocked users...</p>
      </div>
    </div>
  </div>

  <script>
    const CORRECT_KEY = "8867"; // ✅ YOUR KEYCODE

    window.onload = () => {
      if (localStorage.getItem("secret_auth") === "ok") showDashboard();
    };

    function checkKey() {
      const key = document.getElementById('keyInput').value.trim();
      if (key === CORRECT_KEY) {
        localStorage.setItem("secret_auth", "ok");
        showDashboard();
      } else {
        alert("❌ Wrong keycode!");
      }
    }

    function showDashboard() {
      document.getElementById('loginScreen').classList.add('hidden');
      document.getElementById('dashboardScreen').classList.remove('hidden');
      loadBlockedUsers();
    }

    function logout() {
      localStorage.removeItem("secret_auth");
      location.reload();
    }

    // 📥 LOAD BLOCKED USERS FROM SERVER
    async function loadBlockedUsers() {
      const res = await fetch("/api/get-blocked");
      const users = await res.json();
      renderUsers(users);
    }

    function renderUsers(users) {
      const list = document.getElementById('blockedList');
      if (users.length === 0) {
        list.innerHTML = "<p class='text-gray-500 text-center py-5'>✅ No blocked users</p>";
        return;
      }

      list.innerHTML = "";
      users.forEach(u => {
        const div = document.createElement('div');
        div.className = "p-4 border border-gray200 rounded-lg bg-gray50 flex flex-col md:flex-row md:items-center md:justify-between gap-3";
        div.innerHTML = `
          <div>
            <h3 class="font-bold">${u.name}</h3>
            <p class="text-sm text-gray-600">${u.email}</p>
            <p class="text-xs text-danger mt-1">Reason: ${u.reason || "Violation"}</p>
          </div>
          <button onclick="unblockUser('${u.id}')" class="bg-success text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-success/90 transition">
            <i class="fa fa-unlock"></i> Unblock
          </button>
        `;
        list.appendChild(div);
      });
    }

    // 🔍 SEARCH FILTER
    function filterUsers() {
      const term = document.getElementById('searchInput').value.toLowerCase();
      fetch("/api/get-blocked").then(r=>r.json()).then(users=>{
        const filtered = users.filter(u => u.name.toLowerCase().includes(term));
        renderUsers(filtered);
      });
    }

    // 🔓 UNBLOCK USER
    async function unblockUser(userId) {
      if (!confirm("Unblock this user?")) return;
      await fetch("/api/unblock-user", {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({id: userId})
      });
      loadBlockedUsers();
    }
  </script>
</body>
</html>
